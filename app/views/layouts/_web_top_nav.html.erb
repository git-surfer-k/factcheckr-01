<%# @TASK P1-S0-T1 - 웹 상단 네비게이션 파셜 %>
<%# 데스크톱에서만 표시 (모바일에서는 hidden) %>
<%# Trust Blue(#1E40AF) 기반 디자인 %>

<nav
  data-nav="web-top"
  class="hidden md:flex fixed top-0 left-0 right-0 z-50 items-center justify-between bg-white border-b border-gray-100 px-6 lg:px-8 h-14 shadow-sm"
  aria-label="주 네비게이션"
>
  <%# 로고 %>
  <div class="flex items-center">
    <%= link_to root_path, class: "text-xl font-bold text-blue-800 hover:text-blue-900 transition-colors", aria: { label: "FactCheckr 홈" } do %>
      FactCheckr
    <% end %>
  </div>

  <%# 가운데 메뉴 %>
  <div class="flex items-center gap-8">
    <%= link_to "홈", root_path,
      class: "text-sm font-medium transition-colors #{current_page?(root_path) ? 'text-blue-800 font-semibold' : 'text-gray-600 hover:text-blue-800'}" %>
    <%= link_to "채널 랭킹", ranking_path,
      class: "text-sm font-medium transition-colors #{current_page?(ranking_path) ? 'text-blue-800 font-semibold' : 'text-gray-600 hover:text-blue-800'}" %>
    <%= link_to "내 기록", history_path,
      class: "text-sm font-medium transition-colors #{current_page?(history_path) ? 'text-blue-800 font-semibold' : 'text-gray-600 hover:text-blue-800'}" %>
  </div>

  <%# 오른쪽: 알림 + 프로필 %>
  <div class="flex items-center gap-3">
    <%# 알림 버튼 %>
    <button
      class="w-10 h-10 flex items-center justify-center rounded-full text-gray-500 hover:bg-gray-100 transition-colors"
      aria-label="알림"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
      </svg>
    </button>

    <%# 프로필 버튼 (로그인 상태에 따라 다르게 표시) %>
    <% if defined?(current_user) && current_user %>
      <button
        class="w-9 h-9 flex items-center justify-center rounded-full bg-blue-800 text-white text-sm font-semibold hover:bg-blue-900 transition-colors"
        aria-label="프로필 메뉴"
        aria-haspopup="true"
      >
        <%= current_user.email&.first&.upcase || "U" %>
      </button>
    <% else %>
      <%# 로그인하지 않은 경우: 설정 아이콘으로 대체 %>
      <%= link_to settings_path,
        class: "w-10 h-10 flex items-center justify-center rounded-full text-gray-500 hover:bg-gray-100 transition-colors",
        aria: { label: "설정" } do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      <% end %>
    <% end %>
  </div>
</nav>
