<!DOCTYPE html>
<%# @TASK ADMIN-T1 - 관리자 전용 레이아웃 %>
<%# 어두운 테마 (bg-gray-900), 사이드바 네비게이션 %>
<html lang="ko">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} — Factis Admin" : "Factis Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%# Pretendard 폰트 %>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      crossorigin="anonymous"
    >

    <%# Tailwind CSS %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-sans antialiased bg-gray-900 text-gray-100 min-h-screen">
    <%# Flash 메시지 %>
    <% if flash[:notice] %>
      <div
        role="alert"
        class="fixed top-4 left-1/2 -translate-x-1/2 z-[100] bg-green-600 text-white px-6 py-3 rounded-lg shadow-lg text-sm font-medium"
      >
        <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div
        role="alert"
        class="fixed top-4 left-1/2 -translate-x-1/2 z-[100] bg-red-600 text-white px-6 py-3 rounded-lg shadow-lg text-sm font-medium"
      >
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if content_for?(:skip_sidebar) %>
      <%# 로그인 페이지: 사이드바 없는 전체 화면 %>
      <main role="main">
        <%= yield %>
      </main>
    <% else %>
      <%# 사이드바 네비게이션 %>
      <nav
        aria-label="관리자 메인 네비게이션"
        class="fixed inset-y-0 left-0 z-40 flex flex-col w-60 bg-gray-800 text-white"
      >
        <%# 로고 영역 %>
        <div class="flex items-center gap-3 px-5 py-5 border-b border-gray-700">
          <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-indigo-600 shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
              />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-bold leading-tight">Factis</p>
            <p class="text-xs text-gray-400 leading-tight">Admin</p>
          </div>
        </div>

        <%# 메뉴 목록 %>
        <ul class="flex flex-col gap-1 px-3 py-4 flex-1" role="list">
          <%# 대시보드 %>
          <li>
            <%= link_to admin_root_path,
                  class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path == admin_root_path ? 'bg-gray-700 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}",
                  aria: { current: request.path == admin_root_path ? "page" : nil } do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                />
              </svg>
              대시보드
            <% end %>
          </li>

          <%# 사용자 관리 %>
          <li>
            <%= link_to admin_users_path,
                  class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/admin/users') ? 'bg-gray-700 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}",
                  aria: { current: request.path.start_with?('/admin/users') ? "page" : nil } do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"
                />
              </svg>
              사용자 관리
            <% end %>
          </li>

          <%# API 설정 %>
          <li>
            <%= link_to admin_settings_path,
                  class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path.start_with?('/admin/settings') ? 'bg-gray-700 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}",
                  aria: { current: request.path.start_with?('/admin/settings') ? "page" : nil } do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
                />
              </svg>
              API 설정
            <% end %>
          </li>
        </ul>

        <%# 하단 로그아웃 %>
        <div class="px-3 py-4 border-t border-gray-700">
          <%= button_to admin_logout_path, method: :delete, class: "flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-700 hover:text-white transition-colors" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
              />
            </svg>
            <span>로그아웃</span>
          <% end %>
        </div>
      </nav>

      <%# 메인 콘텐츠 (사이드바 너비만큼 마진) %>
      <main role="main" class="ml-60 min-h-screen">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
