<!DOCTYPE html>
<%# @TASK P5-S1-T1 - B2B 전용 레이아웃 %>
<%# 로그인 페이지는 사이드바 없는 심플 레이아웃 %>
<%# Trust Blue(#1E40AF) 기반 B2B 브랜드 디자인 %>
<html lang="ko" data-layout="b2b" data-theme="trust-blue">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "FactCheckr for Business — 기업 광고적합성 분석" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <meta name="description" content="유튜브 채널 신뢰도를 AI로 분석하여 기업 광고 적합성을 평가합니다.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Pretendard 폰트 (한글 최적화) %>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      crossorigin="anonymous"
    >

    <%# Tailwind CSS %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-sans antialiased bg-blue-50 text-gray-900 min-h-screen">
    <%# Flash 메시지 (페이지 상단 고정) %>
    <% if flash[:notice] %>
      <div
        role="alert"
        aria-live="polite"
        class="fixed top-4 left-1/2 -translate-x-1/2 z-[100] bg-blue-800 text-white px-6 py-3 rounded-lg shadow-lg text-sm font-medium"
      >
        <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div
        role="alert"
        aria-live="assertive"
        class="fixed top-4 left-1/2 -translate-x-1/2 z-[100] bg-red-600 text-white px-6 py-3 rounded-lg shadow-lg text-sm font-medium"
      >
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%# @TASK P5-S2-T1 - 사이드바 네비게이션 (로그인 페이지 제외) %>
    <% if content_for?(:skip_sidebar) %>
      <%# 로그인 페이지 등 사이드바가 필요 없는 페이지 %>
      <main role="main">
        <%= yield %>
      </main>
    <% else %>
      <%# 대시보드 등 사이드바가 필요한 B2B 페이지 %>
      <%= render "layouts/b2b_sidebar" %>
      <%# 사이드바 너비(w-60 = 240px)만큼 메인 콘텐츠를 오른쪽으로 밀어냄 %>
      <main role="main" class="ml-60 min-h-screen bg-blue-50">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
