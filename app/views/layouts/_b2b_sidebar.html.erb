<%# @TASK P5-S2-T1 - B2B 사이드바 네비게이션 파셜 %>
<%# @SPEC specs/screens/b2b-dashboard.yaml#sidebar_nav %>
<%# Trust Blue 기반 B2B 사이드바: 대시보드/새 리포트/결제 관리 %>

<nav
  data-nav="b2b-sidebar"
  aria-label="B2B 메인 네비게이션"
  class="fixed inset-y-0 left-0 z-40 flex flex-col w-60 bg-blue-900 text-white"
>
  <%# 로고 영역 %>
  <div class="flex items-center gap-3 px-5 py-5 border-b border-blue-800">
    <%# 방패 아이콘 %>
    <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-blue-700 shrink-0">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
        />
      </svg>
    </div>
    <div>
      <p class="text-sm font-bold leading-tight">FactCheckr</p>
      <p class="text-xs text-blue-300 leading-tight">for Business</p>
    </div>
  </div>

  <%# 메뉴 목록 %>
  <ul class="flex flex-col gap-1 px-3 py-4 flex-1" role="list">

    <%# 대시보드 %>
    <li>
      <%= link_to b2b_dashboard_path,
            class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{request.path == b2b_dashboard_path ? 'bg-blue-700 text-white' : 'text-blue-200 hover:bg-blue-800 hover:text-white'}",
            aria: { current: request.path == b2b_dashboard_path ? "page" : nil } do %>
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
          />
        </svg>
        대시보드
      <% end %>
    </li>

    <%# 새 리포트 %>
    <li>
      <%= link_to b2b_new_report_path,
            class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors text-blue-200 hover:bg-blue-800 hover:text-white" do %>
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 4v16m8-8H4"
          />
        </svg>
        새 리포트
      <% end %>
    </li>

    <%# 결제 관리 %>
    <li>
      <%= link_to b2b_billing_path,
            class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors text-blue-200 hover:bg-blue-800 hover:text-white" do %>
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
          />
        </svg>
        결제 관리
      <% end %>
    </li>
  </ul>

  <%# 하단 로그아웃 영역 %>
  <div class="px-3 py-4 border-t border-blue-800">
    <button
      type="button"
      class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-sm font-medium text-blue-300 hover:bg-blue-800 hover:text-white transition-colors"
      aria-label="로그아웃"
    >
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
        />
      </svg>
      로그아웃
    </button>
  </div>
</nav>
