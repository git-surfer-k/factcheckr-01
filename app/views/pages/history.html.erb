<%# 팩트체크 기록 (더보기) — 전체 결과를 페이지네이션으로 표시 %>
<% content_for :title, "팩트체크 기록 — Factis" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 pt-6 pb-24 md:pb-12">

    <%# ===== 페이지 헤더 ===== %>
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-blue-900">팩트체크 기록</h1>
        <p class="text-sm text-gray-400 mt-1">총 <%= @total_count %>건</p>
      </div>
      <% if logged_in? %>
        <span class="text-sm text-gray-400"><%= current_web_user.email %></span>
      <% end %>
    </div>

    <% if @fact_checks.any? %>
      <section data-component="history-list" aria-label="팩트체크 기록 목록">

        <%# ===== 데스크톱: 3열 카드 그리드 ===== %>
        <div class="hidden md:grid md:grid-cols-3 gap-4">
          <% @fact_checks.each do |check| %>
            <%= link_to report_path(check.id),
              class: "bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-md hover:border-blue-100 transition-all group",
              aria: { label: "#{check.video_title.presence || '팩트체크 결과'} 보기" } do %>

              <div class="aspect-video bg-gray-100 overflow-hidden relative">
                <% if check.video_thumbnail.present? %>
                  <img src="<%= check.video_thumbnail %>" alt="<%= check.video_title %> 썸네일"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
                <% else %>
                  <div class="w-full h-full flex items-center justify-center">
                    <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                <% end %>
                <% unless check.completed? %>
                  <span class="absolute top-2 left-2 text-xs font-semibold px-2 py-0.5 rounded-full
                    <%= check.analyzing? ? 'bg-blue-100 text-blue-700' : check.pending? ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>">
                    <%= check.analyzing? ? "분석 중" : check.pending? ? "대기 중" : "실패" %>
                  </span>
                <% end %>
              </div>

              <div class="p-3 flex items-start justify-between gap-2">
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-semibold text-gray-800 line-clamp-2 leading-snug mb-1">
                    <%= check.video_title.presence || "제목 없음" %>
                  </p>
                  <p class="text-xs text-gray-400">
                    <%= check.channel&.name %> &middot; <%= relative_time(check.created_at) %>
                  </p>
                </div>
                <% if check.overall_score %>
                  <div class="flex-shrink-0 text-sm font-bold <%= score_color_classes(check.overall_score.to_i) %> px-2 py-0.5 rounded-md"
                    aria-label="팩트체크 점수 <%= check.overall_score.to_i %>점">
                    <%= check.overall_score.to_i %>점
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>

        <%# ===== 모바일: 리스트 레이아웃 ===== %>
        <ul class="md:hidden flex flex-col gap-3" role="list">
          <% @fact_checks.each do |check| %>
            <li>
              <%= link_to report_path(check.id),
                class: "bg-white rounded-xl border border-gray-100 p-3 flex items-center gap-3 hover:border-blue-100 hover:shadow-sm transition-all",
                aria: { label: "#{check.video_title.presence || '팩트체크 결과'} 보기" } do %>

                <div class="w-16 h-12 bg-gray-100 rounded-lg overflow-hidden flex-shrink-0">
                  <% if check.video_thumbnail.present? %>
                    <img src="<%= check.video_thumbnail %>" alt="" class="w-full h-full object-cover" loading="lazy" aria-hidden="true">
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center">
                      <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                  <% end %>
                </div>

                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-gray-800 line-clamp-2 leading-snug">
                    <%= check.video_title.presence || "제목 없음" %>
                  </p>
                  <p class="text-xs text-gray-400 mt-0.5">
                    <%= check.channel&.name %> &middot; <%= relative_time(check.created_at) %>
                  </p>
                </div>

                <% if check.overall_score %>
                  <div class="flex-shrink-0 w-11 h-11 rounded-full flex items-center justify-center text-sm font-bold <%= score_color_classes(check.overall_score.to_i) %>"
                    aria-label="점수 <%= check.overall_score.to_i %>점">
                    <%= check.overall_score.to_i %>
                  </div>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>

        <%# ===== 더보기 버튼 ===== %>
        <% if @has_more %>
          <div class="mt-8 text-center">
            <%= link_to history_path(count: @load_count + @per_load),
              class: "inline-flex items-center gap-2 px-8 py-3 border border-gray-300 rounded-xl text-sm font-medium text-gray-600 bg-white hover:bg-gray-50 hover:border-blue-300 hover:text-blue-700 transition-all" do %>
              더보기
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            <% end %>
          </div>
          <p class="text-center text-xs text-gray-400 mt-2">
            <%= @fact_checks.size %>건 / 총 <%= @total_count %>건
          </p>
        <% else %>
          <p class="text-center text-xs text-gray-400 mt-8">
            전체 <%= @total_count %>건을 모두 표시했습니다
          </p>
        <% end %>

      </section>

    <% else %>
      <%# ===== 빈 상태 ===== %>
      <div data-component="history-empty" class="flex flex-col items-center justify-center py-20 text-center">
        <div class="w-20 h-20 bg-blue-50 rounded-3xl flex items-center justify-center mb-5">
          <svg class="w-10 h-10 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <p class="text-gray-700 font-semibold text-base mb-1">아직 팩트체크 기록이 없습니다</p>
        <p class="text-gray-400 text-sm mb-6">유튜브 영상 URL을 입력해 첫 팩트체크를 시작해보세요</p>
        <%= link_to root_path,
          class: "inline-flex items-center gap-2 bg-blue-800 text-white px-6 py-3 rounded-xl font-semibold text-sm hover:bg-blue-900 transition-colors" do %>
          첫 팩트체크 시작하기
        <% end %>
      </div>
    <% end %>

  </div>
</div>
