<%# @TASK P4-S2-T1 - 설정 화면 UI %>
<%# @SPEC specs/screens/b2c-settings.yaml %>
<%# 프로필 수정, 구독 관리, 로그아웃 기능을 제공하는 설정 페이지 %>
<% content_for :title, "설정 — FactCheckr" %>

<div class="min-h-screen bg-gray-50 px-4 pt-6 pb-24 md:pb-12">
  <div class="max-w-lg mx-auto">

    <%# ===== 페이지 제목 ===== %>
    <h1 class="text-2xl font-bold text-blue-900 mb-6">설정</h1>

    <%# ===== ProfileSection: 프로필 정보 ===== %>
    <section
      data-component="profile-section"
      class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-4"
      aria-label="프로필 정보"
    >
      <h2 class="text-base font-semibold text-gray-800 mb-4">내 프로필</h2>

      <%# 아바타 + 이름/이메일 %>
      <div class="flex items-center gap-4 mb-5">
        <%# 이니셜 아바타 (이미지 없는 경우 이메일 첫 글자) %>
        <div
          class="w-14 h-14 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0"
          aria-hidden="true"
        >
          <span class="text-xl font-bold text-blue-700">
            <%= (current_web_user.name.presence || current_web_user.email).first.upcase %>
          </span>
        </div>

        <div class="min-w-0">
          <p class="text-base font-semibold text-gray-900 truncate">
            <%= current_web_user.name.presence || "이름 없음" %>
          </p>
          <%# 이메일은 수정 불가 — 단순 표시만 %>
          <p class="text-sm text-gray-500 truncate"><%= current_web_user.email %></p>
        </div>
      </div>

      <%# 이름 수정 폼 %>
      <form
        data-component="name-edit-form"
        data-action-form="update-name"
        class="space-y-3"
        novalidate
      >
        <%# CSRF 토큰은 meta 태그에서 가져와 JS로 처리 %>
        <div>
          <label for="name-input" class="block text-xs font-medium text-gray-600 mb-1">
            이름
          </label>
          <input
            id="name-input"
            type="text"
            name="name"
            value="<%= current_web_user.name %>"
            placeholder="이름을 입력하세요"
            maxlength="50"
            class="w-full px-4 py-3 text-sm text-gray-800 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:border-blue-400 focus:bg-white focus:ring-2 focus:ring-blue-100 transition-all"
            aria-label="이름 입력"
            autocomplete="name"
          >
        </div>

        <%# 저장 버튼 %>
        <button
          type="submit"
          data-action="save-name"
          class="w-full bg-blue-800 text-white py-3 rounded-xl font-semibold text-sm hover:bg-blue-900 active:bg-blue-950 transition-colors"
          aria-label="이름 저장"
        >
          저장
        </button>

        <%# 결과 메시지 표시 영역 %>
        <div
          data-name-result
          class="text-sm text-center hidden"
          aria-live="polite"
          role="status"
        ></div>
      </form>
    </section>

    <%# ===== SubscriptionSection: 구독 상태 카드 ===== %>
    <section
      data-component="subscription-section"
      class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-4"
      aria-label="구독 관리"
    >
      <h2 class="text-base font-semibold text-gray-800 mb-4">구독 관리</h2>

      <% if @current_subscription %>
        <%# 활성 구독이 있는 경우 %>
        <%# 플랜 표시 레이블 매핑 %>
        <% plan_label = {
          "b2c_basic"       => "베이직",
          "b2c_premium"     => "프리미엄",
          "b2b_standard"    => "B2B 스탠다드",
          "b2b_enterprise"  => "B2B 엔터프라이즈"
        }[@current_subscription.plan_type] || @current_subscription.plan_type %>

        <%# 현재 플랜 배지 + 만료일 %>
        <div class="flex items-center justify-between mb-4">
          <div>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-800">
              <%= plan_label %> 플랜
            </span>
          </div>
          <% if @current_subscription.expires_at %>
            <p class="text-xs text-gray-400">
              만료: <%= @current_subscription.expires_at.strftime("%Y.%m.%d") %>
            </p>
          <% end %>
        </div>

        <%# 결제 수단 %>
        <% if @current_subscription.payment_method.present? %>
          <div class="flex items-center gap-2 mb-4 text-sm text-gray-600">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
            <span><%= @current_subscription.payment_method %></span>
          </div>
        <% end %>

        <%# 구독 변경/취소 버튼 (MVP: UI만, 기능은 추후 구현) %>
        <div class="flex gap-2">
          <button
            type="button"
            data-action="change-plan"
            class="flex-1 py-2.5 rounded-xl text-sm font-semibold border border-blue-200 text-blue-700 hover:bg-blue-50 transition-colors"
            aria-label="구독 플랜 변경"
          >
            플랜 변경
          </button>
          <button
            type="button"
            data-action="cancel-plan"
            class="flex-1 py-2.5 rounded-xl text-sm font-semibold border border-gray-200 text-gray-500 hover:bg-gray-50 transition-colors"
            aria-label="구독 취소"
          >
            구독 취소
          </button>
        </div>

      <% else %>
        <%# 활성 구독이 없는 경우 — 무료 플랜 안내 %>
        <div class="flex items-center justify-between mb-4">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">
            무료 플랜
          </span>
          <p class="text-xs text-gray-400">제한된 기능 사용 중</p>
        </div>

        <%# 업그레이드 안내 %>
        <p class="text-sm text-gray-500 mb-4">
          유료 구독으로 업그레이드하면 무제한 팩트체크와 상세 리포트를 이용할 수 있습니다.
        </p>

        <button
          type="button"
          data-action="upgrade-plan"
          class="w-full bg-blue-800 text-white py-3 rounded-xl font-semibold text-sm hover:bg-blue-900 active:bg-blue-950 transition-colors"
          aria-label="구독 업그레이드"
        >
          구독 업그레이드
        </button>
      <% end %>
    </section>

    <%# ===== LogoutButton: 로그아웃 ===== %>
    <section class="mb-4">
      <button
        type="button"
        data-component="logout-button"
        data-action="logout"
        class="w-full bg-white border border-gray-200 text-red-500 py-4 rounded-2xl font-semibold text-sm hover:bg-red-50 hover:border-red-100 active:bg-red-100 transition-colors shadow-sm"
        aria-label="로그아웃"
      >
        로그아웃
      </button>
    </section>

  </div>
</div>

<%# ===== JavaScript: 이름 수정 + 로그아웃 처리 ===== %>
<script>
    // 이름 수정 폼 처리
    (function() {
      const form = document.querySelector("form[data-component='name-edit-form']");
      if (!form) return;

      form.addEventListener("submit", async function(e) {
        e.preventDefault();

        const nameInput = form.querySelector("input[name='name']");
        const saveBtn = form.querySelector("[data-action='save-name']");
        const resultEl = form.querySelector("[data-name-result]");
        const name = nameInput ? nameInput.value.trim() : "";

        // 버튼 비활성화 (중복 제출 방지)
        if (saveBtn) {
          saveBtn.disabled = true;
          saveBtn.textContent = "저장 중...";
        }

        try {
          const csrfToken = document.querySelector('meta[name="csrf-token"]')
            ? document.querySelector('meta[name="csrf-token"]').getAttribute("content")
            : "";

          // PATCH /api/v1/users/me — 이름 업데이트
          const response = await fetch("/api/v1/users/me", {
            method: "PATCH",
            headers: {
              "Content-Type": "application/json",
              "X-CSRF-Token": csrfToken
            },
            body: JSON.stringify({ name: name })
          });

          if (response.ok) {
            // 성공 메시지 표시
            if (resultEl) {
              resultEl.textContent = "이름이 저장되었습니다.";
              resultEl.className = "text-sm text-center text-green-600";
              setTimeout(function() {
                resultEl.className = "text-sm text-center hidden";
              }, 3000);
            }
          } else {
            const err = await response.json().catch(function() { return {}; });
            if (resultEl) {
              resultEl.textContent = err.detail || "저장에 실패했습니다.";
              resultEl.className = "text-sm text-center text-red-600";
            }
          }
        } catch (networkError) {
          if (resultEl) {
            resultEl.textContent = "네트워크 오류가 발생했습니다.";
            resultEl.className = "text-sm text-center text-red-600";
          }
        } finally {
          if (saveBtn) {
            saveBtn.disabled = false;
            saveBtn.textContent = "저장";
          }
        }
      });
    })();

    // 로그아웃 버튼 처리
    (function() {
      const logoutBtn = document.querySelector("[data-component='logout-button']");
      if (!logoutBtn) return;

      logoutBtn.addEventListener("click", async function() {
        logoutBtn.disabled = true;
        logoutBtn.textContent = "로그아웃 중...";

        try {
          const csrfToken = document.querySelector('meta[name="csrf-token"]')
            ? document.querySelector('meta[name="csrf-token"]').getAttribute("content")
            : "";

          // 세션 토큰을 쿠키에서 읽기
          const sessionToken = document.cookie.split(';')
            .find(c => c.trim().startsWith('session_token='));
          const token = sessionToken ? sessionToken.trim().split('=')[1] : '';

          // DELETE /api/v1/auth/logout — 세션 삭제
          await fetch("/api/v1/auth/logout", {
            method: "DELETE",
            headers: {
              "Content-Type": "application/json",
              "X-Session-Token": token
            }
          });

          // 세션 쿠키 삭제 후 홈으로 이동
          document.cookie = "session_token=; path=/; max-age=0";
          window.location.href = "/";
        } catch (networkError) {
          // 네트워크 오류 시에도 /auth로 이동 시도
          window.location.href = "/auth";
        }
      });
    })();
</script>
