<%# B2C 로그인/회원가입 페이지 (Email OTP) %>
<% content_for(:title) { "로그인 — FactCheckr" } %>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
  <div class="w-full max-w-md">
    <%# 로고 + 타이틀 %>
    <div class="text-center mb-8">
      <a href="/" class="inline-block">
        <h1 class="text-3xl font-bold text-blue-800">FactCheckr</h1>
      </a>
      <p class="mt-2 text-gray-500">유튜브 시사·뉴스 채널 AI 팩트체크</p>
    </div>

    <%# 로그인/회원가입 카드 %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden" data-component="auth-form">

      <%# 탭: 로그인 / 회원가입 %>
      <div class="flex border-b border-gray-200" id="auth-tabs">
        <button
          id="tab-login"
          onclick="switchTab('login')"
          class="flex-1 py-3.5 text-sm font-semibold text-center border-b-2 border-blue-800 text-blue-800 transition-colors"
        >
          로그인
        </button>
        <button
          id="tab-signup"
          onclick="switchTab('signup')"
          class="flex-1 py-3.5 text-sm font-semibold text-center border-b-2 border-transparent text-gray-400 hover:text-gray-600 transition-colors"
        >
          회원가입
        </button>
      </div>

      <div class="p-8">
        <%# Step 1: 이메일 입력 %>
        <div id="step-email" data-step="email">
          <p id="auth-description" class="text-sm text-gray-500 mb-6">
            이메일을 입력하면 인증 코드를 보내드려요
          </p>

          <form id="email-form" onsubmit="requestOtp(event)">
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">이메일</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autofocus
              placeholder="you@example.com"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            >

            <%# 회원가입 시 이름 입력 (로그인에서는 숨김) %>
            <div id="name-field" class="hidden mt-3">
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">이름 (선택)</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="홍길동"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
              >
            </div>

            <div id="email-error" class="hidden mt-2 text-sm text-red-600"></div>

            <button
              type="submit"
              id="email-submit"
              class="w-full mt-4 px-4 py-3 bg-blue-800 text-white rounded-lg font-medium hover:bg-blue-900 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
            >
              인증 코드 받기
            </button>
          </form>

          <%# 하단 안내 텍스트 %>
          <p id="auth-footer" class="text-center text-xs text-gray-400 mt-5">
            계정이 없으시면 <button onclick="switchTab('signup')" class="text-blue-600 hover:underline font-medium">회원가입</button>을 눌러주세요
          </p>
        </div>

        <%# Step 2: OTP 입력 %>
        <div id="step-otp" class="hidden" data-step="otp">
          <button onclick="goBackToEmail()" class="flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            이메일 변경
          </button>

          <h2 class="text-xl font-semibold text-gray-900 mb-2">인증 코드 입력</h2>
          <p class="text-sm text-gray-500 mb-1">
            <span id="sent-email" class="font-medium text-gray-700"></span>
          </p>
          <p class="text-sm text-gray-500 mb-6">으로 전송된 6자리 코드를 입력하세요</p>

          <form id="otp-form" onsubmit="verifyOtp(event)">
            <label for="otp-code" class="block text-sm font-medium text-gray-700 mb-1">인증 코드</label>
            <input
              type="text"
              id="otp-code"
              name="otp_code"
              required
              maxlength="6"
              pattern="[0-9]{6}"
              inputmode="numeric"
              placeholder="000000"
              autocomplete="one-time-code"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-center text-2xl tracking-[0.5em] font-mono"
            >
            <div id="otp-hint" class="hidden mt-2 text-sm text-blue-600"></div>
            <div id="otp-error" class="hidden mt-2 text-sm text-red-600"></div>
            <button
              type="submit"
              id="otp-submit"
              class="w-full mt-4 px-4 py-3 bg-blue-800 text-white rounded-lg font-medium hover:bg-blue-900 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
            >
              확인
            </button>
          </form>

          <button onclick="requestOtp(null, true)" class="w-full mt-3 text-sm text-gray-500 hover:text-blue-700">
            인증 코드 다시 받기
          </button>
        </div>

        <%# Step 3: 회원가입 완료 환영 메시지 %>
        <div id="step-welcome" class="hidden text-center py-6" data-step="welcome">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2" id="welcome-title">환영합니다!</h2>
          <p class="text-sm text-gray-500 mb-6" id="welcome-message">회원가입이 완료되었습니다.</p>
          <a href="/" class="inline-block px-6 py-3 bg-blue-800 text-white rounded-lg font-medium hover:bg-blue-900 transition-colors">
            팩트체크 시작하기
          </a>
        </div>
      </div>
    </div>

    <%# 서비스 약관 안내 %>
    <p class="text-center text-xs text-gray-400 mt-6 leading-relaxed">
      계속 진행하면 <a href="#" class="underline">이용약관</a>과
      <a href="#" class="underline">개인정보처리방침</a>에 동의하게 됩니다.
    </p>
  </div>
</div>

<script>
  let userEmail = "";
  let authMode = "login"; // "login" 또는 "signup"

  // 탭 전환
  function switchTab(mode) {
    authMode = mode;
    const tabLogin = document.getElementById("tab-login");
    const tabSignup = document.getElementById("tab-signup");
    const nameField = document.getElementById("name-field");
    const desc = document.getElementById("auth-description");
    const footer = document.getElementById("auth-footer");
    const submitBtn = document.getElementById("email-submit");

    if (mode === "signup") {
      tabSignup.className = "flex-1 py-3.5 text-sm font-semibold text-center border-b-2 border-blue-800 text-blue-800 transition-colors";
      tabLogin.className = "flex-1 py-3.5 text-sm font-semibold text-center border-b-2 border-transparent text-gray-400 hover:text-gray-600 transition-colors";
      nameField.classList.remove("hidden");
      desc.textContent = "이메일과 이름을 입력하면 간편하게 가입됩니다";
      footer.innerHTML = '이미 계정이 있으시면 <button onclick="switchTab(\'login\')" class="text-blue-600 hover:underline font-medium">로그인</button>을 눌러주세요';
      submitBtn.textContent = "회원가입";
    } else {
      tabLogin.className = "flex-1 py-3.5 text-sm font-semibold text-center border-b-2 border-blue-800 text-blue-800 transition-colors";
      tabSignup.className = "flex-1 py-3.5 text-sm font-semibold text-center border-b-2 border-transparent text-gray-400 hover:text-gray-600 transition-colors";
      nameField.classList.add("hidden");
      desc.textContent = "이메일을 입력하면 인증 코드를 보내드려요";
      footer.innerHTML = '계정이 없으시면 <button onclick="switchTab(\'signup\')" class="text-blue-600 hover:underline font-medium">회원가입</button>을 눌러주세요';
      submitBtn.textContent = "인증 코드 받기";
    }
  }

  // Step 1: OTP 요청
  async function requestOtp(event, isResend) {
    if (event) event.preventDefault();

    const email = isResend ? userEmail : document.getElementById("email").value.trim();
    if (!email) return;

    const submitBtn = document.getElementById("email-submit");
    const errorEl = document.getElementById("email-error");
    errorEl.classList.add("hidden");

    if (!isResend) {
      submitBtn.disabled = true;
      submitBtn.textContent = "전송 중...";
    }

    try {
      const nameInput = document.getElementById("name");
      const userName = nameInput ? nameInput.value.trim() : "";
      const payload = { email: email };
      if (authMode === "signup" && userName) payload.name = userName;

      const res = await fetch("/api/v1/auth/request_otp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      const data = await res.json();

      if (res.ok) {
        userEmail = email;
        document.getElementById("step-email").classList.add("hidden");
        document.getElementById("step-otp").classList.remove("hidden");
        document.getElementById("sent-email").textContent = email;
        document.getElementById("otp-submit").textContent = authMode === "signup" ? "가입 완료" : "로그인";
        // 이메일 발송 실패 시 OTP가 응답에 포함됨 — 자동 입력
        if (data.otp_code) {
          document.getElementById("otp-code").value = data.otp_code;
          document.getElementById("otp-hint").textContent = "이메일 발송이 불가하여 인증 코드가 자동 입력되었습니다.";
          document.getElementById("otp-hint").classList.remove("hidden");
        }
        document.getElementById("otp-code").focus();
      } else {
        errorEl.textContent = data.error || "인증 코드 전송에 실패했습니다";
        errorEl.classList.remove("hidden");
      }
    } catch (e) {
      errorEl.textContent = "네트워크 오류가 발생했습니다";
      errorEl.classList.remove("hidden");
    } finally {
      if (!isResend) {
        submitBtn.disabled = false;
        submitBtn.textContent = authMode === "signup" ? "회원가입" : "인증 코드 받기";
      }
    }
  }

  // Step 2: OTP 검증
  async function verifyOtp(event) {
    event.preventDefault();

    const otpCode = document.getElementById("otp-code").value.trim();
    if (!otpCode || otpCode.length !== 6) return;

    const submitBtn = document.getElementById("otp-submit");
    const errorEl = document.getElementById("otp-error");
    errorEl.classList.add("hidden");

    submitBtn.disabled = true;
    submitBtn.textContent = "확인 중...";

    try {
      const res = await fetch("/api/v1/auth/verify_otp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: userEmail, otp_code: otpCode })
      });

      const data = await res.json();

      if (res.ok) {
        // 세션 토큰을 쿠키에 저장
        document.cookie = "session_token=" + data.session_token + "; path=/; SameSite=Lax";

        if (authMode === "signup") {
          // 회원가입 모드: 환영 메시지 표시
          document.getElementById("step-otp").classList.add("hidden");
          document.getElementById("step-welcome").classList.remove("hidden");
          document.getElementById("auth-tabs").classList.add("hidden");
        } else {
          // 로그인 모드: 바로 홈으로
          window.location.href = "/";
        }
      } else {
        errorEl.textContent = data.error || "인증 코드가 올바르지 않습니다";
        errorEl.classList.remove("hidden");
        document.getElementById("otp-code").value = "";
        document.getElementById("otp-code").focus();
      }
    } catch (e) {
      errorEl.textContent = "네트워크 오류가 발생했습니다";
      errorEl.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = authMode === "signup" ? "가입 완료" : "로그인";
    }
  }

  // 이메일 변경 (Step 1로)
  function goBackToEmail() {
    document.getElementById("step-otp").classList.add("hidden");
    document.getElementById("step-email").classList.remove("hidden");
    document.getElementById("email").focus();
  }

  // URL 파라미터로 탭 자동 전환 (?mode=signup)
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get("mode") === "signup") switchTab("signup");
</script>
