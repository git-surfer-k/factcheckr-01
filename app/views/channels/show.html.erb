<%# @TASK P3-S1-T1 - 채널 상세 화면 UI %>
<%# @SPEC specs/screens/b2c-channel-detail.yaml %>
<%# 디자인 참조: design/screens/web-channel-detail.png, design/screens/b2c-channel-detail.png %>
<%# 구성: ChannelHeader / SubMetrics / ScoreTrendChart / CheckHistory %>
<% content_for :title, "#{@channel.name} — FactCheckr" %>

<div class="min-h-screen bg-gray-50 pb-20 md:pb-8">
  <div class="max-w-4xl mx-auto px-4 pt-6 md:pt-8">

    <%# ===== 뒤로가기 버튼 ===== %>
    <button
      onclick="history.back()"
      class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-blue-700 hover:bg-blue-50 px-3 py-1.5 rounded-lg mb-4 transition-all"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      이전 페이지
    </button>

    <%# ===== ChannelHeader: 채널 썸네일 + 이름 + 구독자 + 신뢰도 점수 ===== %>
    <section
      data-component="channel-header"
      class="bg-white rounded-2xl p-5 md:p-6 shadow-sm border border-gray-100 mb-5"
      aria-label="채널 정보"
    >
      <div class="flex items-start gap-4">

        <%# 채널 썸네일 %>
        <div class="flex-shrink-0">
          <% if @channel.thumbnail_url.present? %>
            <img
              src="<%= @channel.thumbnail_url %>"
              alt="<%= @channel.name %> 채널 썸네일"
              class="w-16 h-16 md:w-20 md:h-20 rounded-full object-cover bg-gray-100"
            >
          <% else %>
            <%# 썸네일 없는 경우 이니셜 아바타 %>
            <div
              class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-blue-100 flex items-center justify-center"
              aria-hidden="true"
            >
              <span class="text-2xl md:text-3xl font-bold text-blue-800">
                <%= @channel.name.first %>
              </span>
            </div>
          <% end %>
        </div>

        <%# 채널 이름 + 구독자 + 카테고리 + 신뢰도 점수 %>
        <div class="flex-1 min-w-0">
          <h1
            class="text-xl md:text-2xl font-bold text-gray-900 truncate"
            data-field="channel-name"
          >
            <%= @channel.name %>
          </h1>

          <%# 구독자 수 + 카테고리 %>
          <div class="flex flex-wrap items-center gap-2 mt-1">
            <span class="text-sm text-gray-500" data-field="subscriber-count">
              구독자
              <% count = @channel.subscriber_count.to_i %>
              <% if count >= 10_000 %>
                <%= number_with_precision(count / 10_000.0, precision: 1).delete(".0") %>만
              <% else %>
                <%= number_with_delimiter(count) %>
              <% end %>명
            </span>
            <% if @channel.category.present? %>
              <span
                class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full font-medium"
                data-field="category"
              >
                <%= @channel.category %>
              </span>
            <% end %>
          </div>

          <%# 신뢰도 점수 + 라벨 %>
          <div class="flex items-center gap-2 mt-2">
            <span class="text-xs text-gray-500">신뢰도</span>
            <span
              class="text-lg font-bold <%= score_number_class(@channel.trust_score) %>"
              data-field="trust-score"
            >
              <%= @channel.trust_score.to_i %>점
            </span>
            <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= score_color_classes(@channel.trust_score.to_i) %>">
              <%= score_label(@channel.trust_score.to_i) %>
            </span>
          </div>

          <%# 설명 (있는 경우에만 표시) %>
          <% if @channel.description.present? %>
            <p class="text-sm text-gray-500 mt-2 line-clamp-2">
              <%= @channel.description %>
            </p>
          <% end %>
        </div>
      </div>
    </section>

    <%# ===== SubMetrics: 3개 세부 지표 카드 (최신 점수 기준) ===== %>
    <section
      data-component="sub-metrics"
      class="mb-5"
      aria-label="세부 신뢰도 지표"
    >
      <div class="grid grid-cols-3 gap-3">

        <%# 정확도 카드 %>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 text-center">
          <p class="text-xs text-gray-500 mb-1">정확도</p>
          <% accuracy = @latest_score&.accuracy_rate.to_f %>
          <p
            class="text-2xl font-bold <%= score_number_class(accuracy) %>"
            data-field="accuracy-rate"
          >
            <%= accuracy.to_i %>%
          </p>
        </div>

        <%# 출처 인용률 카드 %>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 text-center">
          <p class="text-xs text-gray-500 mb-1">출처 인용</p>
          <% citation = @latest_score&.source_citation_rate.to_f %>
          <p
            class="text-2xl font-bold <%= score_number_class(citation) %>"
            data-field="source-citation-rate"
          >
            <%= citation.to_i %>%
          </p>
        </div>

        <%# 논조 일관성 카드 %>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 text-center">
          <p class="text-xs text-gray-500 mb-1">일관성</p>
          <% consistency = @latest_score&.consistency_score.to_f %>
          <p
            class="text-2xl font-bold <%= score_number_class(consistency) %>"
            data-field="consistency-score"
          >
            <%= consistency.to_i %>%
          </p>
        </div>

      </div>
    </section>

    <%# ===== ScoreTrendChart: 신뢰도 추이 차트 (SVG 라인 차트) ===== %>
    <section
      data-component="score-trend-chart"
      class="bg-white rounded-2xl p-5 md:p-6 shadow-sm border border-gray-100 mb-5"
      aria-label="신뢰도 추이"
    >
      <h2 class="text-sm font-semibold text-gray-500 mb-4">신뢰도 추이</h2>

      <% if @channel_scores.length >= 2 %>
        <%#
          SVG 라인 차트:
          - 가로: 100% 너비, 세로: 120px 고정
          - 점수 0~100 범위를 Y축으로 매핑
          - 데이터 포인트를 연결하는 폴리라인 그리기
        %>
        <%
          scores = @channel_scores.map { |s| s.score.to_f }
          min_score = [ scores.min - 5, 0 ].max
          max_score = [ scores.max + 5, 100 ].min
          score_range = [ max_score - min_score, 1 ].max  # 0 나누기 방지

          chart_width = 400
          chart_height = 120
          padding_x = 20
          padding_y = 10

          # 각 점수를 SVG 좌표로 변환하는 람다
          to_x = ->(i) { padding_x + i * ((chart_width - padding_x * 2).to_f / [ @channel_scores.length - 1, 1 ].max) }
          to_y = ->(score) { chart_height - padding_y - ((score - min_score).to_f / score_range * (chart_height - padding_y * 2)) }

          # 폴리라인 포인트 문자열 생성
          points = @channel_scores.each_with_index.map { |s, i| "#{to_x.call(i).round(1)},#{to_y.call(s.score.to_f).round(1)}" }.join(" ")
        %>

        <div class="w-full overflow-hidden" aria-hidden="true">
          <svg
            viewBox="0 0 <%= chart_width %> <%= chart_height %>"
            class="w-full"
            style="height: 120px;"
            role="img"
            aria-label="신뢰도 점수 추이 차트"
          >
            <%# 배경 그라디언트 영역 %>
            <defs>
              <linearGradient id="score-gradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#1E40AF" stop-opacity="0.15" />
                <stop offset="100%" stop-color="#1E40AF" stop-opacity="0.02" />
              </linearGradient>
            </defs>

            <%# 영역 채우기 (맨 아래까지 연결) %>
            <%
              first_x = to_x.call(0).round(1)
              last_x = to_x.call(@channel_scores.length - 1).round(1)
              fill_points = "#{first_x},#{chart_height} #{points} #{last_x},#{chart_height}"
            %>
            <polygon
              points="<%= fill_points %>"
              fill="url(#score-gradient)"
            />

            <%# 라인 %>
            <polyline
              points="<%= points %>"
              fill="none"
              stroke="#1E40AF"
              stroke-width="2"
              stroke-linejoin="round"
              stroke-linecap="round"
            />

            <%# 데이터 포인트 원 %>
            <% @channel_scores.each_with_index do |s, i| %>
              <circle
                cx="<%= to_x.call(i).round(1) %>"
                cy="<%= to_y.call(s.score.to_f).round(1) %>"
                r="3"
                fill="#1E40AF"
                stroke="white"
                stroke-width="1.5"
              />
            <% end %>
          </svg>
        </div>

        <%# X축 날짜 레이블 %>
        <div class="flex justify-between mt-2 px-2">
          <% [ @channel_scores.first, @channel_scores.last ].compact.each_with_index do |s, i| %>
            <span class="text-xs text-gray-400">
              <%= s.recorded_at&.strftime("%m/%d") || "-" %>
            </span>
          <% end %>
        </div>

      <% else %>
        <%# 데이터가 부족한 경우 안내 메시지 %>
        <div class="h-32 flex items-center justify-center bg-gray-50 rounded-xl">
          <p class="text-sm text-gray-400">추이 데이터가 충분하지 않습니다 (최소 2건 필요)</p>
        </div>
      <% end %>
    </section>

    <%# ===== CheckHistory: 팩트체크 이력 목록 ===== %>
    <section
      data-component="check-history"
      aria-label="검증 이력"
    >
      <h2 class="text-sm font-semibold text-gray-500 mb-3">검증 이력</h2>

      <% if @fact_checks.any? %>
        <ul class="space-y-3" role="list">
          <% @fact_checks.each do |fc| %>
            <li
              data-component="check-history-item"
              class="bg-white rounded-xl shadow-sm border border-gray-100 hover:border-blue-200 transition-colors"
            >
              <%# 리포트 상세(/reports/:id)로 이동하는 링크 %>
              <%= link_to report_path(fc.id),
                class: "flex items-center justify-between px-4 py-4 gap-3",
                aria: { label: "#{fc.video_title} 팩트체크 리포트 보기" } do %>

                <%# 영상 제목 + 날짜 %>
                <div class="flex-1 min-w-0">
                  <p
                    class="text-sm font-medium text-gray-800 truncate"
                    data-field="video-title"
                  >
                    <%= fc.video_title.presence || "제목 없음" %>
                  </p>
                  <p class="text-xs text-gray-400 mt-0.5">
                    <%= relative_time(fc.created_at) %>
                  </p>
                </div>

                <%# 점수 배지 %>
                <div
                  class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold border-2 <%= score_border_class(fc.overall_score) %>"
                  aria-label="점수 <%= fc.overall_score.to_i %>점"
                >
                  <span class="<%= score_number_class(fc.overall_score) %>">
                    <%= fc.overall_score.to_i %>
                  </span>
                </div>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <%# 팩트체크 이력이 없는 경우 %>
        <div class="bg-white rounded-xl p-8 text-center border border-gray-100 shadow-sm">
          <svg class="w-10 h-10 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          <p class="text-sm text-gray-400">아직 팩트체크 이력이 없습니다</p>
        </div>
      <% end %>
    </section>

  </div>
</div>
