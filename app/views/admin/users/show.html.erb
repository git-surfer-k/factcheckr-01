<%# @TASK ADMIN-T1 - 관리자 사용자 상세 페이지 %>
<% content_for(:title) { "#{@user.email} — 사용자 상세" } %>

<div class="p-6 lg:p-8">
  <%# 뒤로가기 + 제목 %>
  <div class="mb-6">
    <%= link_to "← 사용자 목록", admin_users_path, class: "text-sm text-gray-400 hover:text-gray-300" %>
    <h1 class="text-2xl font-bold text-white mt-2"><%= @user.name || @user.email %></h1>
  </div>

  <%# 사용자 정보 카드 %>
  <div class="bg-gray-800 rounded-xl border border-gray-700 p-6 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div>
        <p class="text-sm text-gray-400 mb-1">이메일</p>
        <p class="text-white font-medium"><%= @user.email %></p>
      </div>
      <div>
        <p class="text-sm text-gray-400 mb-1">이름</p>
        <p class="text-white font-medium"><%= @user.name || "(미설정)" %></p>
      </div>
      <div>
        <p class="text-sm text-gray-400 mb-1">타입</p>
        <span class="inline-block px-2 py-0.5 text-xs rounded-full <%= @user.b2b? ? 'bg-blue-900 text-blue-300' : 'bg-gray-700 text-gray-300' %>">
          <%= @user.user_type.upcase %>
        </span>
      </div>
      <div>
        <p class="text-sm text-gray-400 mb-1">가입일</p>
        <p class="text-white"><%= @user.created_at.strftime("%Y-%m-%d %H:%M") %></p>
      </div>
    </div>

    <%# 활성화/비활성화 버튼 %>
    <div class="mt-6 pt-4 border-t border-gray-700 flex items-center gap-4">
      <div class="flex items-center gap-2">
        <span class="inline-block w-2.5 h-2.5 rounded-full <%= @user.is_active ? 'bg-green-400' : 'bg-red-400' %>"></span>
        <span class="text-sm text-gray-300"><%= @user.is_active ? "활성" : "비활성" %></span>
      </div>
      <%= button_to @user.is_active ? "비활성화" : "활성화",
            toggle_active_admin_user_path(@user),
            method: :patch,
            class: "px-4 py-2 text-sm rounded-lg transition-colors #{@user.is_active ? 'bg-red-900/50 text-red-300 hover:bg-red-900' : 'bg-green-900/50 text-green-300 hover:bg-green-900'}",
            data: { turbo_confirm: "#{@user.email} 사용자를 #{@user.is_active ? '비활성화' : '활성화'}하시겠습니까?" } %>
    </div>
  </div>

  <%# 팩트체크 목록 %>
  <div class="bg-gray-800 rounded-xl border border-gray-700 mb-6">
    <div class="px-5 py-4 border-b border-gray-700">
      <h2 class="text-lg font-semibold text-white">팩트체크 기록 (<%= @user.fact_checks.count %>건)</h2>
    </div>
    <div class="divide-y divide-gray-700">
      <% @fact_checks.each do |fc| %>
        <div class="px-5 py-3 flex items-center justify-between">
          <div class="min-w-0 flex-1 mr-4">
            <p class="text-sm text-white truncate"><%= fc.channel&.name || "(채널 없음)" %></p>
            <p class="text-xs text-gray-400 truncate"><%= fc.youtube_url %></p>
          </div>
          <div class="text-right shrink-0">
            <% fc_status_class = case fc.status
               when 'completed' then 'bg-green-900 text-green-300'
               when 'analyzing' then 'bg-yellow-900 text-yellow-300'
               when 'pending' then 'bg-gray-700 text-gray-300'
               when 'failed' then 'bg-red-900 text-red-300'
               else 'bg-gray-700 text-gray-300'
               end %>
            <span class="inline-block px-2 py-0.5 text-xs rounded-full <%= fc_status_class %>">
              <%= fc.status %>
            </span>
            <p class="text-xs text-gray-500 mt-0.5"><%= fc.created_at.strftime("%Y-%m-%d") %></p>
          </div>
        </div>
      <% end %>

      <% if @fact_checks.empty? %>
        <div class="px-5 py-8 text-center text-gray-500 text-sm">팩트체크 기록이 없습니다.</div>
      <% end %>
    </div>
  </div>

  <%# 구독 이력 %>
  <div class="bg-gray-800 rounded-xl border border-gray-700">
    <div class="px-5 py-4 border-b border-gray-700">
      <h2 class="text-lg font-semibold text-white">구독 이력 (<%= @subscriptions.count %>건)</h2>
    </div>
    <div class="divide-y divide-gray-700">
      <% @subscriptions.each do |sub| %>
        <div class="px-5 py-3 flex items-center justify-between">
          <div>
            <p class="text-sm text-white"><%= sub.plan_type.humanize %></p>
            <p class="text-xs text-gray-400">
              <%= sub.started_at&.strftime("%Y-%m-%d") || "-" %> ~
              <%= sub.expires_at&.strftime("%Y-%m-%d") || "-" %>
            </p>
          </div>
          <% sub_status_class = case sub.status
             when 'active' then 'bg-green-900 text-green-300'
             when 'canceled' then 'bg-yellow-900 text-yellow-300'
             when 'expired' then 'bg-gray-700 text-gray-400'
             else 'bg-gray-700 text-gray-400'
             end %>
          <span class="inline-block px-2 py-0.5 text-xs rounded-full <%= sub_status_class %>">
            <%= sub.status %>
          </span>
        </div>
      <% end %>

      <% if @subscriptions.empty? %>
        <div class="px-5 py-8 text-center text-gray-500 text-sm">구독 이력이 없습니다.</div>
      <% end %>
    </div>
  </div>
</div>
