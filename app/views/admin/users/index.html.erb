<%# @TASK ADMIN-T1 - 관리자 사용자 목록 페이지 %>
<% content_for(:title) { "사용자 관리" } %>

<div class="p-6 lg:p-8">
  <%# 페이지 제목 %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white">사용자 관리</h1>
    <p class="text-sm text-gray-400 mt-1">전체 <%= @total_count %>명의 사용자</p>
  </div>

  <%# 사용자 테이블 %>
  <div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-700 bg-gray-800/50">
            <th class="text-left px-5 py-3 text-gray-400 font-medium">이메일</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">이름</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">타입</th>
            <th class="text-left px-5 py-3 text-gray-400 font-medium">가입일</th>
            <th class="text-center px-5 py-3 text-gray-400 font-medium">팩트체크</th>
            <th class="text-center px-5 py-3 text-gray-400 font-medium">상태</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-700">
          <% @users.each do |user| %>
            <tr class="hover:bg-gray-750 transition-colors">
              <td class="px-5 py-3">
                <%= link_to user.email, admin_user_path(user), class: "text-indigo-400 hover:text-indigo-300" %>
              </td>
              <td class="px-5 py-3 text-gray-300"><%= user.name || "-" %></td>
              <td class="px-5 py-3">
                <span class="inline-block px-2 py-0.5 text-xs rounded-full <%= user.b2b? ? 'bg-blue-900 text-blue-300' : 'bg-gray-700 text-gray-300' %>">
                  <%= user.user_type.upcase %>
                </span>
              </td>
              <td class="px-5 py-3 text-gray-400"><%= user.created_at.strftime("%Y-%m-%d") %></td>
              <td class="px-5 py-3 text-center text-gray-300"><%= user.fact_checks.count %></td>
              <td class="px-5 py-3 text-center">
                <span class="inline-block w-2 h-2 rounded-full <%= user.is_active ? 'bg-green-400' : 'bg-red-400' %>"></span>
              </td>
            </tr>
          <% end %>

          <% if @users.empty? %>
            <tr>
              <td colspan="6" class="px-5 py-8 text-center text-gray-500">등록된 사용자가 없습니다.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# 페이지네이션 %>
    <% if @total_pages > 1 %>
      <div class="px-5 py-4 border-t border-gray-700 flex items-center justify-between">
        <p class="text-sm text-gray-400">
          페이지 <%= @page %> / <%= @total_pages %>
        </p>
        <div class="flex gap-2">
          <% if @page > 1 %>
            <%= link_to "이전", admin_users_path(page: @page - 1),
                  class: "px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-lg transition-colors" %>
          <% end %>
          <% if @page < @total_pages %>
            <%= link_to "다음", admin_users_path(page: @page + 1),
                  class: "px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-lg transition-colors" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
