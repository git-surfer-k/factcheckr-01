<%# @TASK ADMIN-T1 - 관리자 API 설정 페이지 %>
<%# @TASK ADMIN-T2 - Resend 테스트 이메일 버튼 %>
<% content_for(:title) { "API 설정" } %>

<div class="p-6 lg:p-8">
  <%# 페이지 제목 %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white">API 설정</h1>
    <p class="text-sm text-gray-400 mt-1">외부 API 키와 시스템 설정을 관리합니다.</p>
  </div>

  <%# 설정 폼 %>
  <%= form_tag(admin_settings_path, method: :patch, class: "space-y-6") do %>

    <%# AI 모델 설정 %>
    <div class="bg-gray-800 rounded-xl border border-gray-700">
      <div class="px-5 py-4 border-b border-gray-700">
        <h2 class="text-lg font-semibold text-white">AI 모델 설정</h2>
        <p class="text-xs text-gray-400 mt-0.5">OpenAI API 연동 설정</p>
      </div>
      <div class="p-5 space-y-4">
        <div>
          <label for="settings_openai_api_key" class="block text-sm font-medium text-gray-300 mb-1.5">OpenAI API Key</label>
          <input
            type="text"
            id="settings_openai_api_key"
            name="settings[openai_api_key]"
            value="<%= @settings['openai_api_key'][:display] %>"
            placeholder="sk-..."
            class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm"
          >
        </div>
        <div>
          <label for="settings_openai_model" class="block text-sm font-medium text-gray-300 mb-1.5">모델명</label>
          <input
            type="text"
            id="settings_openai_model"
            name="settings[openai_model]"
            value="<%= @settings['openai_model'][:value] %>"
            placeholder="gpt-4o"
            class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm"
          >
        </div>
      </div>
    </div>

    <%# 빅카인즈 API 설정 %>
    <div class="bg-gray-800 rounded-xl border border-gray-700">
      <div class="px-5 py-4 border-b border-gray-700">
        <h2 class="text-lg font-semibold text-white">빅카인즈 API</h2>
        <p class="text-xs text-gray-400 mt-0.5">뉴스 빅데이터 검색 설정</p>
      </div>
      <div class="p-5 space-y-4">
        <div>
          <label for="settings_bigkinds_api_key" class="block text-sm font-medium text-gray-300 mb-1.5">API Key</label>
          <input
            type="text"
            id="settings_bigkinds_api_key"
            name="settings[bigkinds_api_key]"
            value="<%= @settings['bigkinds_api_key'][:display] %>"
            placeholder="API 키를 입력하세요"
            class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm"
          >
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="settings_bigkinds_return_size" class="block text-sm font-medium text-gray-300 mb-1.5">검색 결과 수</label>
            <input
              type="number"
              id="settings_bigkinds_return_size"
              name="settings[bigkinds_return_size]"
              value="<%= @settings['bigkinds_return_size'][:value] %>"
              min="1" max="100"
              class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm"
            >
          </div>
          <div>
            <label for="settings_bigkinds_search_days" class="block text-sm font-medium text-gray-300 mb-1.5">검색 기간 (일)</label>
            <input
              type="number"
              id="settings_bigkinds_search_days"
              name="settings[bigkinds_search_days]"
              value="<%= @settings['bigkinds_search_days'][:value] %>"
              min="1" max="365"
              class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm"
            >
          </div>
        </div>
      </div>
    </div>

    <%# 이메일 설정 (Resend) %>
    <div class="bg-gray-800 rounded-xl border border-gray-700">
      <div class="px-5 py-4 border-b border-gray-700 flex items-center justify-between">
        <div>
          <h2 class="text-lg font-semibold text-white">이메일 설정 (Resend)</h2>
          <p class="text-xs text-gray-400 mt-0.5">Resend API를 통한 이메일 발송 설정</p>
        </div>
      </div>
      <div class="p-5 space-y-4">
        <div>
          <label for="settings_resend_api_key" class="block text-sm font-medium text-gray-300 mb-1.5">Resend API Key</label>
          <input
            type="text"
            id="settings_resend_api_key"
            name="settings[resend_api_key]"
            value="<%= @settings['resend_api_key'][:display] %>"
            placeholder="re_..."
            class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm"
          >
        </div>
        <div>
          <label for="settings_resend_from_email" class="block text-sm font-medium text-gray-300 mb-1.5">발신자 이메일</label>
          <input
            type="text"
            id="settings_resend_from_email"
            name="settings[resend_from_email]"
            value="<%= @settings['resend_from_email'][:value] %>"
            placeholder="Factis <noreply@factis.com>"
            class="w-full px-4 py-2.5 bg-gray-900 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm"
          >
        </div>
      </div>
    </div>

    <%# 저장 버튼 %>
    <div class="flex items-center gap-4">
      <button
        type="submit"
        class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-gray-900 text-sm"
      >
        설정 저장
      </button>
    </div>
  <% end %>

  <%# 테스트 이메일 발송 %>
  <div class="mt-6 bg-gray-800 rounded-xl border border-gray-700">
    <div class="px-5 py-4 border-b border-gray-700">
      <h2 class="text-lg font-semibold text-white">이메일 테스트</h2>
      <p class="text-xs text-gray-400 mt-0.5">관리자 이메일(<%= ENV.fetch("ADMIN_EMAIL", "admin@factis.com") %>)로 테스트 메일을 발송합니다.</p>
    </div>
    <div class="p-5">
      <%= button_to "테스트 이메일 발송", test_email_admin_settings_path, method: :post,
            class: "px-4 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white font-medium rounded-lg transition-colors text-sm" %>
    </div>
  </div>

  <%# 시스템 상태 %>
  <div class="mt-6 bg-gray-800 rounded-xl border border-gray-700">
    <div class="px-5 py-4 border-b border-gray-700">
      <h2 class="text-lg font-semibold text-white">시스템 상태</h2>
    </div>
    <div class="divide-y divide-gray-700">
      <% @system_status.each do |name, info| %>
        <div class="px-5 py-3 flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-white"><%= name.to_s.humanize %></p>
            <p class="text-xs text-gray-400"><%= info[:detail] %></p>
          </div>
          <% sys_badge_class = case info[:status]
             when 'running' then 'bg-green-900 text-green-300'
             when 'error' then 'bg-red-900 text-red-300'
             when 'offline' then 'bg-gray-700 text-gray-400'
             else 'bg-gray-700 text-gray-400'
             end %>
          <% sys_dot_class = case info[:status]
             when 'running' then 'bg-green-400'
             when 'error' then 'bg-red-400'
             when 'offline' then 'bg-gray-500'
             else 'bg-gray-500'
             end %>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs rounded-full <%= sys_badge_class %>">
            <span class="w-1.5 h-1.5 rounded-full <%= sys_dot_class %>"></span>
            <%= info[:status] %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
</div>
