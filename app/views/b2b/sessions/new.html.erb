<%# @TASK P5-S1-T1 - B2B 로그인 폼 %>
<%# @SPEC specs/screens/b2b-login.yaml (예정) %>
<%# Email OTP 방식으로 기업 계정에 로그인한다. %>
<%# 1단계: 이메일 입력 → OTP 발송 %>
<%# 2단계: OTP 입력 → 로그인 완료 %>

<% content_for :title, "로그인 — Factis for Business" %>
<%# 로그인 페이지는 사이드바를 표시하지 않음 %>
<% content_for :skip_sidebar, true %>

<%# 전체 화면 중앙 정렬 컨테이너 %>
<div class="min-h-screen flex flex-col items-center justify-center px-4 py-12">

  <%# 로그인 카드 %>
  <div class="w-full max-w-md">

    <%# B2B 브랜딩 헤더 %>
    <div class="text-center mb-8" data-component="b2b-brand">
      <%# 로고 %>
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-800 mb-4 shadow-md">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
          />
        </svg>
      </div>

      <%# 서비스 이름 %>
      <h1 class="text-2xl font-bold text-blue-900 tracking-tight">
        Factis for Business
      </h1>
      <p class="mt-1 text-sm text-blue-600">
        기업 광고적합성 분석 플랫폼
      </p>
    </div>

    <%# 로그인 폼 카드 %>
    <div class="bg-white rounded-2xl shadow-sm border border-blue-100 p-8">

      <% if params[:step] == "verify" %>
        <%# 2단계: OTP 입력 화면 %>
        <div data-component="otp-step">
          <h2 class="text-lg font-semibold text-gray-900 mb-1">인증 코드 확인</h2>
          <p class="text-sm text-gray-500 mb-6">
            이메일로 발송된 6자리 인증 코드를 입력해 주세요.
          </p>

          <%= form_with url: b2b_login_path, method: :post,
              data: { component: "b2b-auth-form", step: "verify" } do |f| %>
            <%= hidden_field_tag :step, "verify" %>
            <%= hidden_field_tag :email, session[:b2b_pending_email] %>

            <%# 인증 코드 입력 %>
            <div class="mb-6">
              <%= f.label :otp_code, "인증 코드",
                class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.text_field :otp_code,
                inputmode: "numeric",
                autocomplete: "one-time-code",
                maxlength: 6,
                placeholder: "000000",
                class: "w-full px-4 py-3 text-center text-2xl font-mono tracking-[0.5em] border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-colors",
                "aria-label": "이메일 인증 코드" %>
            </div>

            <%# 검증 버튼 %>
            <button
              type="submit"
              data-action="request-otp"
              class="w-full py-3 px-4 bg-blue-800 hover:bg-blue-900 text-white font-semibold rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
            >
              로그인
            </button>
          <% end %>

          <%# 이메일 재입력 링크 %>
          <p class="mt-4 text-center text-sm text-gray-500">
            다른 이메일로 시도하시겠어요?
            <%= link_to "다시 입력", b2b_login_path, class: "text-blue-700 hover:text-blue-900 font-medium underline underline-offset-2" %>
          </p>
        </div>

      <% else %>
        <%# 1단계: 이메일 입력 화면 %>
        <div data-component="email-step">
          <h2 class="text-lg font-semibold text-gray-900 mb-1">기업 계정 로그인</h2>
          <p class="text-sm text-gray-500 mb-6">
            등록된 기업 이메일 주소를 입력하면 인증 코드를 보내드립니다.
          </p>

          <%= form_with url: b2b_login_path, method: :post,
              data: { component: "b2b-auth-form" } do |f| %>

            <%# 이메일 입력 %>
            <div class="mb-6">
              <%= f.label :email, "기업 이메일",
                class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "company@example.com",
                required: true,
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-colors text-sm",
                "aria-label": "기업 이메일 주소",
                "aria-required": "true" %>
            </div>

            <%# OTP 요청 버튼 %>
            <button
              type="submit"
              data-action="request-otp"
              class="w-full py-3 px-4 bg-blue-800 hover:bg-blue-900 text-white font-semibold rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
            >
              인증 코드 받기
            </button>
          <% end %>
        </div>
      <% end %>

    </div>

    <%# 하단 안내 문구 %>
    <p class="mt-6 text-center text-xs text-gray-400">
      기업 계정이 없으신가요?
      <a href="mailto:business@factis.io" class="text-blue-700 hover:text-blue-900 font-medium">
        비즈니스 문의
      </a>
    </p>

  </div>
</div>
