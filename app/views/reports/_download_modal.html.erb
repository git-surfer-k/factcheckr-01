<%# @TASK P2-S4-T1 - 다운로드 모달 파셜 %>
<%# @SPEC specs/screens/b2c-report-detail.yaml %>
<%# 리포트 다운로드 모달: 형식 선택 + 구독 안내 포함 %>

<%# 모달 배경 오버레이: 클릭 시 모달을 닫는다 %>
<div
  data-component="modal-overlay"
  id="download-modal-overlay"
  class="fixed inset-0 bg-black/50 z-40 hidden"
  onclick="closeDownloadModal()"
  aria-hidden="true"
></div>

<%# 다운로드 모달 컨테이너 %>
<div
  data-component="download-modal"
  id="download-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="download-modal-title"
  class="fixed inset-x-4 bottom-0 sm:inset-auto sm:top-1/2 sm:left-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2 sm:w-full sm:max-w-md z-50 hidden"
>
  <div class="bg-white rounded-t-2xl sm:rounded-2xl shadow-xl border border-gray-100 overflow-hidden">

    <%# 모달 헤더 %>
    <div class="flex items-center justify-between px-5 pt-5 pb-4 border-b border-gray-100">
      <h2
        data-field="modal-title"
        id="download-modal-title"
        class="text-base font-bold text-gray-900"
      >
        리포트 다운로드
      </h2>

      <%# 닫기 버튼 %>
      <button
        data-action="close-modal"
        type="button"
        onclick="closeDownloadModal()"
        class="w-8 h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500"
        aria-label="모달 닫기"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <%# 모달 본문 %>
    <div class="px-5 py-4">

      <%# SubscriptionNotice: 무료 사용자 안내 %>
      <div
        data-component="subscription-notice"
        class="flex items-start gap-3 bg-blue-50 border border-blue-100 rounded-xl px-4 py-3 mb-4"
        role="note"
      >
        <%# 정보 아이콘 %>
        <svg class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 4a8 8 0 100 16 8 8 0 000-16z" />
        </svg>
        <div class="flex-1 min-w-0">
          <p class="text-xs text-blue-800 font-semibold mb-0.5">구독 필요</p>
          <p class="text-xs text-blue-700 leading-relaxed">
            리포트 다운로드는 유료 구독 기능입니다.
            구독 후 PDF, MD, DOCX, HWP 형식으로 다운로드하세요.
          </p>
          <a
            href="/settings"
            class="inline-block mt-2 text-xs font-semibold text-blue-700 underline underline-offset-2 hover:text-blue-900 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded"
          >
            구독 플랜 보기 &rarr;
          </a>
        </div>
      </div>

      <%# 형식 선택 안내 텍스트 %>
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
        다운로드 형식 선택
      </p>

      <%# 형식 선택 카드 그리드 (4종) %>
      <div class="grid grid-cols-2 gap-2 mb-5">

        <%# PDF 형식 %>
        <label
          data-format="pdf"
          class="relative flex flex-col items-center gap-2 p-4 border-2 border-gray-100 rounded-xl cursor-pointer hover:border-blue-300 hover:bg-blue-50/50 transition-colors has-[:checked]:border-blue-700 has-[:checked]:bg-blue-50"
        >
          <input type="radio" name="download_format" value="pdf" class="sr-only" checked>
          <%# PDF 아이콘 %>
          <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center" aria-hidden="true">
            <span class="text-red-600 text-xs font-bold">PDF</span>
          </div>
          <div class="text-center">
            <p class="text-sm font-semibold text-gray-800">PDF</p>
            <p class="text-xs text-gray-400 mt-0.5">범용 문서</p>
          </div>
        </label>

        <%# MD 형식 %>
        <label
          data-format="md"
          class="relative flex flex-col items-center gap-2 p-4 border-2 border-gray-100 rounded-xl cursor-pointer hover:border-blue-300 hover:bg-blue-50/50 transition-colors has-[:checked]:border-blue-700 has-[:checked]:bg-blue-50"
        >
          <input type="radio" name="download_format" value="md" class="sr-only">
          <%# MD 아이콘 %>
          <div class="w-10 h-10 bg-gray-50 rounded-lg flex items-center justify-center" aria-hidden="true">
            <span class="text-gray-600 text-xs font-bold">MD</span>
          </div>
          <div class="text-center">
            <p class="text-sm font-semibold text-gray-800">Markdown</p>
            <p class="text-xs text-gray-400 mt-0.5">개발자용</p>
          </div>
        </label>

        <%# DOCX 형식 %>
        <label
          data-format="docx"
          class="relative flex flex-col items-center gap-2 p-4 border-2 border-gray-100 rounded-xl cursor-pointer hover:border-blue-300 hover:bg-blue-50/50 transition-colors has-[:checked]:border-blue-700 has-[:checked]:bg-blue-50"
        >
          <input type="radio" name="download_format" value="docx" class="sr-only">
          <%# DOCX 아이콘 %>
          <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center" aria-hidden="true">
            <span class="text-blue-600 text-xs font-bold">DOC</span>
          </div>
          <div class="text-center">
            <p class="text-sm font-semibold text-gray-800">Word</p>
            <p class="text-xs text-gray-400 mt-0.5">MS Office</p>
          </div>
        </label>

        <%# HWP 형식 %>
        <label
          data-format="hwp"
          class="relative flex flex-col items-center gap-2 p-4 border-2 border-gray-100 rounded-xl cursor-pointer hover:border-blue-300 hover:bg-blue-50/50 transition-colors has-[:checked]:border-blue-700 has-[:checked]:bg-blue-50"
        >
          <input type="radio" name="download_format" value="hwp" class="sr-only">
          <%# HWP 아이콘 %>
          <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center" aria-hidden="true">
            <span class="text-green-600 text-xs font-bold">HWP</span>
          </div>
          <div class="text-center">
            <p class="text-sm font-semibold text-gray-800">한글</p>
            <p class="text-xs text-gray-400 mt-0.5">한글 문서</p>
          </div>
        </label>

      </div>

      <%# 다운로드 실행 버튼 %>
      <button
        type="button"
        onclick="startDownload()"
        class="w-full py-3 bg-blue-800 hover:bg-blue-900 text-white text-sm font-semibold rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
        aria-label="선택한 형식으로 다운로드 시작"
      >
        <span class="inline-flex items-center gap-2">
          <%# 다운로드 아이콘 %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          다운로드
        </span>
      </button>

    </div>
    <%# 모달 본문 종료 %>

  </div>
</div>
