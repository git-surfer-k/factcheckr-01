<%# @TASK P2-S3-T1 - 리포트 상세 화면 %>
<%# @SPEC specs/screens/b2c-report-detail.yaml %>
<%# 5탭 구조: 콘텐츠 요약 / 팩트 점수 / 주장별 검증 / 근거 뉴스 / 채널 정보 %>
<% content_for :title, "팩트체크 리포트 — #{@fact_check.video_title} — FactCheckr" %>

<%# JavaScript: 탭 전환 + 다운로드 모달 로직 (Stimulus 없이 순수 JS) %>
<% content_for :head do %>
  <script>
    // 탭 전환 함수: 선택된 탭 패널만 표시하고 나머지는 숨긴다.
    function switchTab(tabName) {
      // 모든 탭 버튼 비활성화
      document.querySelectorAll('[data-tab]').forEach(function(btn) {
        btn.setAttribute('aria-selected', 'false');
        btn.classList.remove('border-blue-700', 'text-blue-700');
        btn.classList.add('border-transparent', 'text-gray-500');
      });

      // 모든 탭 패널 숨기기
      document.querySelectorAll('[data-panel]').forEach(function(panel) {
        panel.classList.add('hidden');
      });

      // 선택된 탭 버튼 활성화
      var activeBtn = document.querySelector('[data-tab="' + tabName + '"]');
      if (activeBtn) {
        activeBtn.setAttribute('aria-selected', 'true');
        activeBtn.classList.remove('border-transparent', 'text-gray-500');
        activeBtn.classList.add('border-blue-700', 'text-blue-700');
      }

      // 선택된 탭 패널 표시
      var activePanel = document.querySelector('[data-panel="' + tabName + '"]');
      if (activePanel) {
        activePanel.classList.remove('hidden');
      }
    }

    // 다운로드 모달 열기: 모달과 오버레이를 표시하고 포커스를 이동한다.
    function openDownloadModal() {
      var modal = document.getElementById('download-modal');
      var overlay = document.getElementById('download-modal-overlay');
      if (modal && overlay) {
        modal.classList.remove('hidden');
        overlay.classList.remove('hidden');
        // 접근성: 모달 안 첫 번째 버튼으로 포커스 이동
        var closeBtn = modal.querySelector('[data-action="close-modal"]');
        if (closeBtn) { closeBtn.focus(); }
        // 스크롤 잠금
        document.body.style.overflow = 'hidden';
      }
    }

    // 다운로드 모달 닫기: 모달과 오버레이를 숨기고 스크롤을 복원한다.
    function closeDownloadModal() {
      var modal = document.getElementById('download-modal');
      var overlay = document.getElementById('download-modal-overlay');
      if (modal && overlay) {
        modal.classList.add('hidden');
        overlay.classList.add('hidden');
        document.body.style.overflow = '';
        // 접근성: 모달을 연 다운로드 버튼으로 포커스 복원
        var trigger = document.querySelector('[data-component="download-button"]');
        if (trigger) { trigger.focus(); }
      }
    }

    // ESC 키로 모달 닫기
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { closeDownloadModal(); }
    });

    // 다운로드 시작: MVP에서는 "준비 중" 알림만 표시한다.
    function startDownload() {
      var selected = document.querySelector('input[name="download_format"]:checked');
      var format = selected ? selected.value.toUpperCase() : 'PDF';
      alert(format + ' 다운로드 기능은 준비 중입니다.\n정식 출시 시 이용하실 수 있습니다.');
    }

    // 페이지 로드 시 기본 탭(요약) 활성화
    document.addEventListener('DOMContentLoaded', function() {
      switchTab('summary');
    });

    // 내 기록에 담기/삭제
    async function toggleBookmark(factCheckId) {
      var btn = document.getElementById('bookmark-btn');
      var icon = document.getElementById('bookmark-icon');
      var text = document.getElementById('bookmark-text');
      var isBookmarked = icon.getAttribute('fill') === 'currentColor';

      try {
        var sessionToken = document.cookie.split(';').find(function(c) { return c.trim().startsWith('session_token='); });
        if (!sessionToken) {
          window.location.href = '/auth';
          return;
        }
        var token = sessionToken.trim().split('=')[1];

        var savedClasses = ['bg-yellow-50', 'border-yellow-300', 'text-yellow-700', 'hover:bg-yellow-100', 'focus:ring-yellow-400'];
        var defaultClasses = ['border-gray-300', 'text-gray-600', 'hover:bg-gray-50', 'focus:ring-gray-400'];

        if (isBookmarked) {
          var res = await fetch('/api/v1/bookmarks/' + factCheckId, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json', 'X-Session-Token': token }
          });
          if (res.ok) {
            icon.setAttribute('fill', 'none');
            text.textContent = '내 기록에 담기';
            btn.classList.remove(...savedClasses);
            btn.classList.add(...defaultClasses);
          }
        } else {
          var res = await fetch('/api/v1/bookmarks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Session-Token': token },
            body: JSON.stringify({ fact_check_id: factCheckId })
          });
          if (res.ok || res.status === 201) {
            icon.setAttribute('fill', 'currentColor');
            text.textContent = '저장됨';
            btn.classList.remove(...defaultClasses);
            btn.classList.add(...savedClasses);
          } else if (res.status === 401) {
            window.location.href = '/auth';
          }
        }
      } catch(e) {
        alert('네트워크 오류가 발생했습니다.');
      }
    }
  </script>
<% end %>

<div class="min-h-screen bg-gray-50 pb-20 md:pb-8">
  <div class="max-w-3xl mx-auto px-4 pt-4 md:pt-8">

    <%# ===== 뒤로가기 버튼 ===== %>
    <button
      onclick="history.back()"
      class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-blue-700 hover:bg-blue-50 px-3 py-1.5 rounded-lg mb-4 transition-all"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      이전 페이지
    </button>

    <%# ===== 리포트 헤더 (summary-card) ===== %>
    <div
      data-component="report-header"
      class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4"
    >
      <div class="flex items-start gap-4">
        <%# ScoreBadge: 큰 숫자로 점수 표시 %>
        <div
          data-component="score-badge"
          class="flex-shrink-0 w-16 h-16 rounded-full border-4 flex flex-col items-center justify-center <%= score_border_class(@fact_check.overall_score) %>"
          aria-label="팩트체크 점수 <%= @fact_check.overall_score.to_i %>점"
        >
          <span
            data-field="overall-score"
            class="text-xl font-bold leading-none <%= score_number_class(@fact_check.overall_score) %>"
          >
            <%= @fact_check.overall_score.to_i %>
          </span>
          <span class="text-xs text-gray-400 leading-none">/100</span>
        </div>

        <%# 제목 + 채널 + 날짜 %>
        <div class="flex-1 min-w-0">
          <%# 판정 라벨 뱃지 %>
          <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full mb-1.5 <%= score_color_classes(@fact_check.overall_score) %>">
            <%= score_label(@fact_check.overall_score) %>
          </span>

          <h1
            data-field="video-title"
            class="text-base font-bold text-gray-900 leading-snug line-clamp-2"
          >
            <%= @fact_check.video_title %>
          </h1>

          <div class="flex flex-wrap items-center gap-x-2 mt-1.5 text-xs text-gray-500">
            <span data-field="channel-name" class="font-medium text-gray-700">
              <%= @channel.name %>
            </span>
            <span aria-hidden="true">·</span>
            <time
              data-field="created-at"
              datetime="<%= @fact_check.created_at.iso8601 %>"
            >
              <%= @fact_check.created_at.strftime("%Y.%m.%d") %>
            </time>
            <% if @fact_check.video_thumbnail.present? %>
              <%# 조회수 등 추가 정보 표시 자리 %>
            <% end %>
          </div>
        </div>
      </div>

      <%# 버튼 영역: 내 기록 담기 + 다운로드 %>
      <div class="mt-4 flex justify-end gap-2">
        <%# 내 기록에 담기 버튼 %>
        <button
          id="bookmark-btn"
          type="button"
          onclick="toggleBookmark('<%= @fact_check.id %>')"
          class="inline-flex items-center gap-2 px-4 py-2 border text-sm font-semibold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2
            <%= @bookmarked ? 'bg-yellow-50 border-yellow-300 text-yellow-700 hover:bg-yellow-100 focus:ring-yellow-400' : 'border-gray-300 text-gray-600 hover:bg-gray-50 focus:ring-gray-400' %>"
        >
          <svg id="bookmark-icon" class="w-4 h-4" fill="<%= @bookmarked ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
          </svg>
          <span id="bookmark-text"><%= @bookmarked ? '저장됨' : '내 기록에 담기' %></span>
        </button>

        <%# 다운로드 버튼 %>
        <button
          data-component="download-button"
          data-modal-target="download-modal"
          type="button"
          onclick="openDownloadModal()"
          class="inline-flex items-center gap-2 px-4 py-2 bg-blue-800 hover:bg-blue-900 text-white text-sm font-semibold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
          aria-label="리포트 다운로드"
          aria-haspopup="dialog"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          리포트 다운로드
        </button>
      </div>
    </div>

    <%# ===== AI 면책 고지 (alert) ===== %>
    <div
      data-component="ai-disclaimer"
      role="note"
      class="flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 mb-4"
    >
      <%# 경고 아이콘 %>
      <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M12 4a8 8 0 100 16 8 8 0 000-16z" />
      </svg>
      <p class="text-xs text-amber-700 leading-relaxed">
        AI 검증 결과는 참고용이며, 최종 판단은 근거 뉴스를 직접 확인하세요.
      </p>
    </div>

    <%# ===== 5탭 네비게이션 ===== %>
    <div
      data-component="report-tabs"
      data-controller="report-tabs"
      class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden"
    >
      <%# 탭 버튼 목록 %>
      <div
        role="tablist"
        aria-label="리포트 섹션"
        class="flex border-b border-gray-100 overflow-x-auto scrollbar-none"
      >
        <%# 탭 1: 콘텐츠 요약 %>
        <button
          data-tab="summary"
          role="tab"
          aria-controls="panel-summary"
          aria-selected="true"
          onclick="switchTab('summary')"
          class="flex-1 min-w-0 whitespace-nowrap px-3 py-3.5 text-sm font-medium border-b-2 border-blue-700 text-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-500"
        >
          콘텐츠 요약
        </button>

        <%# 탭 2: 팩트 점수 %>
        <button
          data-tab="score"
          role="tab"
          aria-controls="panel-score"
          aria-selected="false"
          onclick="switchTab('score')"
          class="flex-1 min-w-0 whitespace-nowrap px-3 py-3.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-500"
        >
          팩트 점수
        </button>

        <%# 탭 3: 주장별 검증 %>
        <button
          data-tab="claims"
          role="tab"
          aria-controls="panel-claims"
          aria-selected="false"
          onclick="switchTab('claims')"
          class="flex-1 min-w-0 whitespace-nowrap px-3 py-3.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-500"
        >
          주장별 검증
        </button>

        <%# 탭 4: 근거 뉴스 %>
        <button
          data-tab="news"
          role="tab"
          aria-controls="panel-news"
          aria-selected="false"
          onclick="switchTab('news')"
          class="flex-1 min-w-0 whitespace-nowrap px-3 py-3.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-500"
        >
          근거 뉴스
        </button>

        <%# 탭 5: 채널 정보 %>
        <button
          data-tab="channel"
          role="tab"
          aria-controls="panel-channel"
          aria-selected="false"
          onclick="switchTab('channel')"
          class="flex-1 min-w-0 whitespace-nowrap px-3 py-3.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-500"
        >
          채널 정보
        </button>
      </div>

      <%# ===== 탭 패널 영역 ===== %>

      <%# 탭 패널 1: 콘텐츠 요약 %>
      <div
        id="panel-summary"
        data-panel="summary"
        role="tabpanel"
        aria-labelledby="tab-summary"
        class="p-5"
      >
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">콘텐츠 요약</h2>
        <% if @fact_check.summary.present? %>
          <p
            data-field="summary-text"
            class="text-sm text-gray-700 leading-relaxed"
          >
            <%= @fact_check.summary %>
          </p>
        <% else %>
          <p data-field="summary-text" class="text-sm text-gray-400 italic">
            콘텐츠 요약이 아직 생성되지 않았습니다.
          </p>
        <% end %>
      </div>

      <%# 탭 패널 2: 팩트 점수 %>
      <div
        id="panel-score"
        data-panel="score"
        role="tabpanel"
        aria-labelledby="tab-score"
        class="p-5 hidden"
      >
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">팩트 점수 분석</h2>

        <%# 종합 점수 시각화 %>
        <div class="flex items-center gap-4 mb-5">
          <%# 큰 점수 원형 배지 %>
          <div
            class="w-20 h-20 rounded-full border-4 flex flex-col items-center justify-center flex-shrink-0 <%= score_border_class(@fact_check.overall_score) %>"
            aria-hidden="true"
          >
            <span class="text-2xl font-bold leading-none <%= score_number_class(@fact_check.overall_score) %>">
              <%= @fact_check.overall_score.to_i %>
            </span>
            <span class="text-xs text-gray-400">/100</span>
          </div>
          <div>
            <p class="text-lg font-bold text-gray-900"><%= score_label(@fact_check.overall_score) %></p>
            <p class="text-xs text-gray-500 mt-0.5">종합 팩트체크 점수</p>
          </div>
        </div>

        <%# 점수 바 (시각화) %>
        <div class="mb-5">
          <div class="flex justify-between text-xs text-gray-500 mb-1">
            <span>0</span>
            <span>50</span>
            <span>100</span>
          </div>
          <div class="h-3 bg-gray-100 rounded-full overflow-hidden" aria-hidden="true">
            <div
              class="h-full rounded-full transition-all duration-500 <%= score_bar_class(@fact_check.overall_score) %>"
              style="width: <%= @fact_check.overall_score %>%"
            ></div>
          </div>
        </div>

        <%# 분석 상세 텍스트 %>
        <% if @fact_check.analysis_detail.present? %>
          <div class="bg-gray-50 rounded-xl p-4">
            <h3 class="text-xs font-semibold text-gray-500 mb-2">점수 산출 근거</h3>
            <p class="text-sm text-gray-700 leading-relaxed">
              <%= @fact_check.analysis_detail %>
            </p>
          </div>
        <% end %>

        <%# 주장별 판정 통계 요약 %>
        <% if @claims.any? %>
          <div class="mt-4">
            <h3 class="text-xs font-semibold text-gray-500 mb-3">주장별 판정 현황</h3>
            <div class="grid grid-cols-3 gap-2">
              <% verdict_counts = @claims.group_by(&:verdict).transform_values(&:count) %>
              <%# 사실 계열 %>
              <div class="bg-green-50 rounded-lg p-3 text-center">
                <p class="text-xl font-bold text-green-700">
                  <%= (verdict_counts["true_claim"] || 0) + (verdict_counts["mostly_true"] || 0) %>
                </p>
                <p class="text-xs text-green-600 mt-0.5">사실</p>
              </div>
              <%# 절반 계열 %>
              <div class="bg-yellow-50 rounded-lg p-3 text-center">
                <p class="text-xl font-bold text-yellow-700">
                  <%= verdict_counts["half_true"] || 0 %>
                </p>
                <p class="text-xs text-yellow-600 mt-0.5">절반 사실</p>
              </div>
              <%# 거짓 계열 %>
              <div class="bg-red-50 rounded-lg p-3 text-center">
                <p class="text-xl font-bold text-red-700">
                  <%= (verdict_counts["mostly_false"] || 0) + (verdict_counts["false_claim"] || 0) %>
                </p>
                <p class="text-xs text-red-600 mt-0.5">거짓</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <%# 탭 패널 3: 주장별 검증 (ClaimList) %>
      <div
        id="panel-claims"
        data-panel="claims"
        role="tabpanel"
        aria-labelledby="tab-claims"
        class="p-5 hidden"
      >
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">
          주장별 검증 <span class="text-gray-300 font-normal">(<%= @claims.count %>건)</span>
        </h2>

        <% if @claims.any? %>
          <div class="space-y-3">
            <% @claims.each do |claim| %>
              <%# ClaimCard 컴포넌트 %>
              <% colors = verdict_color_classes(claim.verdict) %>
              <article
                data-component="claim-card"
                class="border rounded-xl p-4 <%= colors[:border] %> <%= colors[:bg] %>"
                aria-label="주장: <%= claim.claim_text&.truncate(50) %>"
              >
                <%# 판정 아이콘 + 라벨 %>
                <div class="flex items-center gap-2 mb-2">
                  <span
                    class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 <%= colors[:text] %>"
                    aria-hidden="true"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <%= verdict_icon_svg(claim.verdict).html_safe %>
                    </svg>
                  </span>
                  <span
                    data-field="verdict"
                    class="text-xs font-semibold <%= colors[:text] %>"
                  >
                    <%= verdict_label(claim.verdict) %>
                  </span>
                  <%# 타임스탬프 %>
                  <% if claim.timestamp_start.present? %>
                    <span class="ml-auto text-xs text-gray-400">
                      <%= format_timestamp(claim.timestamp_start) %>
                    </span>
                  <% end %>
                </div>

                <%# 주장 원문 %>
                <p
                  data-field="claim-text"
                  class="text-sm font-medium text-gray-900 leading-snug mb-2"
                >
                  "<%= claim.claim_text %>"
                </p>

                <%# 확신도 바 %>
                <div class="mb-2" aria-label="확신도 <%= (claim.confidence * 100).to_i %>%">
                  <div class="flex justify-between items-center mb-1">
                    <span class="text-xs text-gray-500">확신도</span>
                    <span class="text-xs font-semibold <%= colors[:text] %>">
                      <%= (claim.confidence * 100).to_i %>%
                    </span>
                  </div>
                  <div
                    data-component="confidence-bar"
                    class="h-1.5 bg-white/60 rounded-full overflow-hidden"
                    aria-hidden="true"
                  >
                    <div
                      class="h-full rounded-full <%= colors[:bar] %>"
                      style="width: <%= (claim.confidence * 100).to_i %>%"
                    ></div>
                  </div>
                </div>

                <%# 검증 설명 %>
                <% if claim.explanation.present? %>
                  <p class="text-xs text-gray-600 leading-relaxed mt-2">
                    <%= claim.explanation %>
                  </p>
                <% end %>

                <%# 근거 뉴스 수 %>
                <% news_count = claim.news_sources.count %>
                <% if news_count > 0 %>
                  <div class="mt-2 pt-2 border-t border-white/40">
                    <span class="text-xs text-gray-500">
                      근거 뉴스 <%= news_count %>건
                    </span>
                  </div>
                <% end %>
              </article>
            <% end %>
          </div>
        <% else %>
          <%# 빈 상태 %>
          <div class="text-center py-10">
            <p class="text-sm text-gray-400">검증된 주장이 없습니다.</p>
          </div>
        <% end %>
      </div>

      <%# 탭 패널 4: 근거 뉴스 (NewsLinks) %>
      <div
        id="panel-news"
        data-panel="news"
        role="tabpanel"
        aria-labelledby="tab-news"
        class="p-5 hidden"
      >
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">
          근거 뉴스 <span class="text-gray-300 font-normal">(<%= @all_news_sources.count %>건)</span>
        </h2>

        <% if @all_news_sources.any? %>
          <div class="space-y-2">
            <% @all_news_sources.each do |news| %>
              <article
                data-component="news-item"
                class="border border-gray-100 rounded-xl p-4 bg-white hover:border-blue-100 hover:bg-blue-50/30 transition-colors"
              >
                <%# 뉴스 제목 링크 %>
                <a
                  href="<%= news.url %>"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block group"
                  aria-label="<%= news.title %> — 새 탭에서 열기"
                >
                  <h3
                    data-field="news-title"
                    class="text-sm font-medium text-gray-900 group-hover:text-blue-700 leading-snug mb-1 transition-colors"
                  >
                    <%= news.title %>
                  </h3>
                </a>

                <%# 언론사 + 날짜 %>
                <div class="flex items-center gap-2 text-xs text-gray-400 flex-wrap">
                  <% if news.publisher.present? %>
                    <span class="font-medium text-gray-500"><%= news.publisher %></span>
                    <span aria-hidden="true">·</span>
                  <% end %>
                  <% if news.published_at.present? %>
                    <time datetime="<%= news.published_at.iso8601 %>">
                      <%= news.published_at.strftime("%Y.%m.%d") %>
                    </time>
                  <% end %>
                  <% if news.relevance_score.present? && news.relevance_score > 0 %>
                    <span aria-hidden="true">·</span>
                    <span>관련도 <%= (news.relevance_score * 100).to_i %>%</span>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <%# 빈 상태 %>
          <div class="text-center py-10">
            <p class="text-sm text-gray-400">근거 뉴스가 없습니다.</p>
          </div>
        <% end %>
      </div>

      <%# 탭 패널 5: 채널 정보 (ChannelInfo) %>
      <div
        id="panel-channel"
        data-panel="channel"
        role="tabpanel"
        aria-labelledby="tab-channel"
        class="p-5 hidden"
      >
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">채널 정보</h2>

        <div
          data-component="channel-info"
          class="bg-gray-50 rounded-xl p-4"
        >
          <%# 채널 기본 정보 %>
          <div class="flex items-center gap-3 mb-4">
            <%# 채널 썸네일 또는 이니셜 아바타 %>
            <% if @channel.thumbnail_url.present? %>
              <img
                src="<%= @channel.thumbnail_url %>"
                alt="<%= @channel.name %> 채널 썸네일"
                class="w-12 h-12 rounded-full object-cover"
              >
            <% else %>
              <div
                class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold text-lg"
                aria-hidden="true"
              >
                <%= @channel.name.first %>
              </div>
            <% end %>

            <div class="flex-1">
              <h3 class="text-base font-bold text-gray-900"><%= @channel.name %></h3>
              <% if @channel.subscriber_count.present? && @channel.subscriber_count > 0 %>
                <p class="text-xs text-gray-500 mt-0.5">
                  구독자 <%= number_with_delimiter(@channel.subscriber_count) %>명
                </p>
              <% end %>
            </div>

            <%# 채널 신뢰도 점수 배지 %>
            <div
              class="flex-shrink-0 w-12 h-12 rounded-full border-3 flex flex-col items-center justify-center <%= score_border_class(@channel.trust_score) %>"
              aria-label="채널 신뢰도 <%= @channel.trust_score.to_i %>점"
            >
              <span class="text-sm font-bold leading-none <%= score_number_class(@channel.trust_score) %>">
                <%= @channel.trust_score.to_i %>
              </span>
              <span class="text-[9px] text-gray-400">점</span>
            </div>
          </div>

          <%# 채널 통계 %>
          <div class="grid grid-cols-2 gap-3 mb-4">
            <div class="bg-white rounded-lg p-3 text-center">
              <p class="text-xl font-bold text-blue-800"><%= @channel.total_checks || 0 %></p>
              <p class="text-xs text-gray-500 mt-0.5">팩트체크 횟수</p>
            </div>
            <div class="bg-white rounded-lg p-3 text-center">
              <p class="text-xl font-bold <%= score_number_class(@channel.trust_score) %>">
                <%= score_label(@channel.trust_score) %>
              </p>
              <p class="text-xs text-gray-500 mt-0.5">신뢰도 등급</p>
            </div>
          </div>

          <%# 채널 상세 이동 버튼 %>
          <%= link_to "#",
            class: "block w-full text-center py-2.5 border border-blue-200 rounded-lg text-sm font-medium text-blue-700 hover:bg-blue-50 transition-colors",
            aria: { label: "#{@channel.name} 채널 상세 보기" } do %>
            채널 상세 보기 &rarr;
          <% end %>
        </div>
      </div>

    </div>
    <%# 탭 패널 영역 종료 %>

  </div>
</div>

<%# 다운로드 모달 파셜 (페이지 하단에 렌더링) %>
<%= render 'download_modal' %>
